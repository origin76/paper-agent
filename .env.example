# Core API / model settings
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAPER_AGENT_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
PAPER_AGENT_DOCUMENT_MODEL=qwen3.5-plus
PAPER_AGENT_ANALYSIS_MODEL=qwen3.5-plus
PAPER_AGENT_ANALYSIS_FALLBACK_MODEL=qwen3.5-plus
PAPER_AGENT_ANALYSIS_STREAM=true
PAPER_AGENT_ANALYSIS_ENABLE_THINKING=true
PAPER_AGENT_ANALYSIS_RETRY_ATTEMPTS=2
PAPER_AGENT_ANALYSIS_RETRY_BACKOFF_SECONDS=2
PAPER_AGENT_WEB_SEARCH_ENABLED=true
PAPER_AGENT_TEMPERATURE=0.2
PAPER_AGENT_MAX_OUTPUT_TOKENS=4096
PAPER_AGENT_TIMEOUT_SECONDS=180
PAPER_AGENT_OUTPUT_ROOT=runs

# Single-paper analysis sizing / parallelism
PAPER_AGENT_PAPER_CONTEXT_MAX_CHARS=180000
PAPER_AGENT_SECTION_TARGET_CHARS=24000
PAPER_AGENT_MAX_SECTIONS=8
PAPER_AGENT_SECTION_MAX_WORKERS=4
PAPER_AGENT_PDF_EXTRACT_TIMEOUT_SECONDS=60
PAPER_AGENT_URL_CONTENT_ENRICHMENT_ENABLED=true
PAPER_AGENT_URL_CONTENT_ENRICHMENT_MAX_URLS=8
PAPER_AGENT_URL_FETCH_TIMEOUT_SECONDS=12
PAPER_AGENT_URL_FETCH_MAX_BYTES=600000
PAPER_AGENT_URL_FETCH_MAX_TEXT_CHARS=6000
PAPER_AGENT_LOG_LEVEL=INFO

# Generic HTTP cookies for venue pages when needed
PAPER_AGENT_COOKIE_HEADER=
PAPER_AGENT_COOKIE_FILE=

# ACM-specific cookies for direct HTTP fallback
PAPER_AGENT_ACM_COOKIE_HEADER=
PAPER_AGENT_ACM_COOKIE_FILE=
PAPER_AGENT_ACM_BROWSER_FALLBACK=false

# Recommended ACM workflow:
#   eval "$(paper-agent-chrome-cdp prepare --profile-directory Default --output shell)"
#   paper-agent-fetch ... --playwright-cdp-url "$PAPER_AGENT_PLAYWRIGHT_CDP_URL"
# If PAPER_AGENT_PLAYWRIGHT_CDP_URL or PAPER_AGENT_PLAYWRIGHT_USER_DATA_DIR is set,
# ACM Playwright handling will auto-enable unless you explicitly disable it with --no-acm-browser-fallback.
PAPER_AGENT_PLAYWRIGHT_CDP_URL=http://127.0.0.1:9222
PAPER_AGENT_PLAYWRIGHT_BROWSER_EXECUTABLE=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome

# Directly pointing Playwright at the live Chrome profile can hit a profile lock.
# Prefer the cloned-profile CDP helper for repeatable ACM batches.
PAPER_AGENT_PLAYWRIGHT_USER_DATA_DIR=~/Library/Application Support/Google/Chrome
PAPER_AGENT_PLAYWRIGHT_PROFILE_DIRECTORY=Default
PAPER_AGENT_PLAYWRIGHT_HEADLESS=false
PAPER_AGENT_PLAYWRIGHT_LAUNCH_TIMEOUT_MS=30000
PAPER_AGENT_PLAYWRIGHT_NAVIGATION_TIMEOUT_MS=45000
PAPER_AGENT_PLAYWRIGHT_DOWNLOAD_POOL_SIZE=4
PAPER_AGENT_PLAYWRIGHT_TOTAL_TIMEOUT_MS=180000
